{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "paulihq-site",
  "main": "dist/server/index.js",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
