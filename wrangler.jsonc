{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "paulihq-site",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "paulihq-auth",
      "database_id": "cd08a903-2354-41a4-8cf4-104be068838b"
    }
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 2,14 * * *"]
  }
}
