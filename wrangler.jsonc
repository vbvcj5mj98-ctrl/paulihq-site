{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "paulihq-site",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "paulihq-auth"
    }
  ],
  "observability": {
    "enabled": true
  }
}
